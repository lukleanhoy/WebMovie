@model WebMovie.Models.Post
@{
    ViewData["Title"] = "Add New Movie";
}

<div class="auth-page-container">
    <div class="auth-card" style="max-width: 600px;">
        <h2 class="auth-title">Add New Movie</h2>
        
        <form asp-controller="Post" asp-action="Create" method="post" autocomplete="off">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            }

            <div class="auth-form-group">
                <input asp-for="Title" class="auth-input" placeholder=" " required />
                <label asp-for="Title" class="auth-input-label">Movie Title</label>
                <span asp-validation-for="Title" class="auth-input-error"></span>
            </div>

            <div class="auth-form-group">
                <textarea asp-for="Description" class="auth-input" placeholder=" " rows="3" style="resize: none; min-height: 100px;" required></textarea>
                <label asp-for="Description" class="auth-input-label">Description / Synopsis</label>
                <span asp-validation-for="Description" class="auth-input-error"></span>
            </div>

            <div class="auth-form-group">
                <input asp-for="ImageUrl" class="auth-input" placeholder=" " required />
                <label asp-for="ImageUrl" class="auth-input-label">Movie Poster Image URL</label>
                <span asp-validation-for="ImageUrl" class="auth-input-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="auth-form-group">
                        <input asp-for="Year" type="number" class="auth-input" placeholder=" " required />
                        <label asp-for="Year" class="auth-input-label">Release Year</label>
                        <span asp-validation-for="Year" class="auth-input-error"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="auth-form-group">
                        <input asp-for="Rating" type="number" step="0.1" class="auth-input" placeholder=" " required />
                        <label asp-for="Rating" class="auth-input-label">IMDb Rating (e.g. 8.5)</label>
                        <span asp-validation-for="Rating" class="auth-input-error"></span>
                    </div>
                </div>
            </div>

            <div class="auth-form-group">
                <select asp-for="Genre" class="auth-input" style="background-color: #333333; color: white;" required>
                    <option value="" disabled selected>Select Genre</option>
                    <option value="Action">Action</option>
                    <option value="Adventure">Adventure</option>
                    <option value="Biography">Biography</option>
                    <option value="Comedy">Comedy</option>
                    <option value="Crime">Crime</option>
                    <option value="Documentary">Documentary</option>
                    <option value="Drama">Drama</option>
                    <option value="Sci-Fi">Sci-Fi</option>
                    <option value="Thriller">Thriller</option>
                </select>
                <span asp-validation-for="Genre" class="auth-input-error"></span>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-premium btn-premium-outline flex-grow-1 text-center justify-content-center">Cancel</a>
                <button type="submit" class="auth-btn flex-grow-1 mb-0">Publish Movie</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
