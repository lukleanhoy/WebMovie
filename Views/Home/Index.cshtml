<!-- Movies Grid Section -->
<section class="content-section" style="margin-top: 30px;">
    <!-- Title & Inline Nav Tabs -->
    <div class="section-header-row">
        <div class="section-title-wrap">
            <i class="bi bi-film"></i>
            <h2 class="section-title">Movies</h2>
        </div>
        
        <!-- Movies Navigation tabs and search -->
        <div class="section-nav-tabs align-items-center">
            <a href="#" class="section-nav-link active">Movies</a>
            <a href="#" class="section-nav-link">Series</a>
            <a href="#" class="section-nav-link">Original Series</a>
            
            <div class="search-input-wrap ms-lg-3">
                <i class="bi bi-search"></i>
                <input type="text" class="search-input" id="movie-search" placeholder="Search title..." onkeyup="filterMoviesByName(this.value)" />
            </div>
        </div>
    </div>
    
    <!-- Category filter badges -->
    <div class="filter-container">
        <div class="filter-wrapper" id="movies-category-wrapper">
            <button class="badge-filter active" onclick="toggleCategoryFilter(this)">Action</button>
            <button class="badge-filter" onclick="toggleCategoryFilter(this)">Adventure</button>
            <button class="badge-filter" onclick="toggleCategoryFilter(this)">Biography</button>
            <button class="badge-filter active" onclick="toggleCategoryFilter(this)">Crime</button>
            <button class="badge-filter" onclick="toggleCategoryFilter(this)">Comedy</button>
            <button class="badge-filter" onclick="toggleCategoryFilter(this)">Documentary</button>
            <button class="badge-filter active" onclick="toggleCategoryFilter(this)">Drama</button>
        </div>
    </div>

    <!-- Secondary Controls Row (Sorting & Rating Slider) -->
    <div class="controls-row">
        <div class="sort-group">
            <span class="sort-label">Sort by:</span>
            <button class="sort-pill active" onclick="toggleSort(this)">Latest</button>
            <select class="sort-select" onchange="alert('Sorted by option successfully!')">
                <option value="year">Year</option>
                <option value="oldest">Oldest</option>
            </select>
            <select class="sort-select" onchange="alert('Sorted alphabetically!')">
                <option value="a-z">A-Z</option>
                <option value="z-a">Z-a</option>
            </select>
        </div>
        
        <!-- Interactive Rating Slider -->
        <div class="rating-slider-wrap">
            <i class="bi bi-star-fill"></i>
            <div class="slider-track" id="slider-track" onclick="adjustRatingSlider(event)">
                <div class="slider-fill" id="slider-fill" style="width: 63%;"></div>
                <div class="slider-handle" id="slider-handle" style="left: 63%;" onmousedown="startDrag(event)"></div>
            </div>
            <span class="rating-value" id="rating-value">6.3</span>
        </div>
    </div>

    <!-- Movie Cards Grid -->
    <div class="movie-grid-container">
        <div class="movie-grid" id="movies-cards-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var post in Model)
                {
                    <div class="movie-card" data-title="@post.Title" onclick="playMovie('@post.Title', '@post.ImageUrl')">
                        <div class="movie-poster-wrap">
                            <img src="@post.ImageUrl" alt="@post.Title" class="movie-poster">
                            <div class="movie-overlay">
                                <div class="overlay-play-btn"><i class="bi bi-play-fill"></i></div>
                            </div>
                        </div>
                        <div class="movie-info-block">
                            <h4 class="movie-card-title">@post.Title</h4>
                            <div class="movie-card-meta">
                                <span>@post.Year</span>
                                <div class="movie-card-rating">
                                    <i class="bi bi-star-fill"></i>
                                    <span class="movie-card-rating-val">@post.Rating.ToString("0.0")</span>
                                </div>
                            </div>
                        </div>
