@model IEnumerable<WebMovie.Models.Post>
@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Banner (Save Me Cover) -->
<section class="hero-banner">
    <div class="hero-content">
        <span class="hero-meta-subtitle">Season 1 &bull; 16 Episode</span>
        
        <h1 class="hero-title">SAVE ME</h1>
        
        <div class="hero-rating-info">
            <span><i class="bi bi-star-fill"></i> <span class="hero-rating-num">9.1</span></span>
            <span>2017</span>
            <span>&bull;</span>
            <span>Exciting story</span>
            <span>&bull;</span>
            <span>2 season</span>
        </div>
        
        <p class="hero-description">
            Series adapted from the webcomic entitled Out of the World by writer Jo Geum-san. A group of young people struggle to rescue their former classmate from a mysterious religious cult.
        </p>
        
        <div class="hero-buttons">
            <button class="btn-premium btn-premium-red" onclick="playMovie('Save Me', 'https://images.unsplash.com/photo-1509198397868-475647b2a1e5?w=1200&q=80')">
                <i class="bi bi-play-fill"></i> WATCH
            </button>
            <button class="btn-premium btn-premium-outline">
                <i class="bi bi-plus-lg"></i> ADD LIST
            </button>
        </div>
    </div>
    
    <!-- Hero Slider Dots -->
    <div class="hero-slider-indicators">
        <span class="slider-dot"></span>
        <span class="slider-dot active"></span>
        <span class="slider-dot"></span>
    </div>
</section>

<!-- Trends Now Section -->
