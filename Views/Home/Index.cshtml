<!-- Full-screen Cinematic Streaming Simulation Modal -->
<div class="modal fade" id="streamModal" tabindex="-1" aria-hidden="true" style="backdrop-filter: blur(20px);">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-fullscreen-lg-down">
        <div class="modal-content border-0 text-white rounded-4 overflow-hidden" style="background-color: #0d0d0d; box-shadow: 0 0 40px rgba(229, 9, 20, 0.4);">
            <!-- Modal Header -->
            <div class="modal-header border-0 bg-transparent px-4 pt-4 pb-0 position-absolute w-100 start-0 top-0 d-flex justify-content-between align-items-center" style="z-index: 100;">
                <h4 class="modal-title fw-bold text-danger" id="streamTitle" style="text-shadow: 0 2px 10px rgba(0,0,0,0.8);">Stream Playback</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="filter: drop-shadow(0 2px 5px rgba(0,0,0,0.9));"></button>
            </div>
            <!-- Modal Body -->
            <div class="modal-body p-0 position-relative">
                <!-- Video Simulator Backing -->
                <div class="ratio ratio-16x9 w-100" style="background-color: #000;">
                    <div class="d-flex flex-column align-items-center justify-content-center text-center p-4 position-relative" id="streamPlayerContainer">
                        <!-- Playback Background Backdrop -->
                        <div id="modalBackdropImg" style="position: absolute; top:0; left:0; width:100%; height:100%; background-size: cover; background-position: center; opacity: 0.25; filter: blur(8px);"></div>
                        
                        <!-- Simulated Controls Glare -->
                        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%); z-index:10;">
                            <div class="d-flex align-items-center gap-3">
                                <button class="btn btn-sm btn-danger rounded-circle p-2" onclick="togglePlayState(this)"><i class="bi bi-pause-fill fs-5"></i></button>
                                <span class="small text-white-50">0:14 / 2:38</span>
                                <div class="progress flex-grow-1 bg-secondary rounded-pill" style="height: 6px; cursor: pointer;">
                                    <div class="progress-bar bg-danger rounded-pill" style="width: 10%;"></div>
                                </div>
                                <i class="bi bi-volume-up-fill fs-5 cursor-pointer"></i>
                                <i class="bi bi-fullscreen fs-5 cursor-pointer ms-2"></i>
                            </div>
                        </div>

                        <!-- Spin loader and message -->
                        <div class="spinner-border text-danger mb-4" role="status" style="width: 4rem; height: 4rem; z-index: 10; box-shadow: 0 0 20px rgba(229, 9, 20, 0.4);">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h2 class="fw-bold mb-2 text-white" id="modalMovieTitle" style="z-index:10; font-family: var(--font-heading); text-shadow: 0 2px 10px rgba(0,0,0,0.9);">MOVIE TITLE</h2>
                        <p class="text-danger-emphasis fs-5 mb-0" id="streamStatusText" style="z-index: 10; letter-spacing: 1px;">BUFFERING CINEMATIC HIGH-SPEED STREAM...</p>
                        <p class="text-white-50 mt-2 small" style="z-index: 10;">Connecting secure P2P node... [1080p Ultra HD Available]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Category Badge Filter Toggles
        function toggleCategoryFilter(button) {
            button.classList.toggle('active');
            if (button.classList.contains('active')) {
                // Subtle feedback accent
                button.style.transform = 'scale(1.05)';
                setTimeout(() => button.style.transform = 'none', 150);
            }
        }

        // Horizontal scroll grid helper
        function scrollGrid(gridId, offset) {
            const grid = document.getElementById(gridId);
            grid.scrollBy({
                left: offset,
                behavior: 'smooth'
            });
        }

        // Live Search Filter for Movies grid
        function filterMoviesByName(query) {
            const searchQuery = query.toLowerCase().trim();
            const cards = document.querySelectorAll('#movies-cards-grid .movie-card');
            
            cards.forEach(card => {
                const title = card.getAttribute('data-title').toLowerCase();
                if (searchQuery === '' || title.includes(searchQuery)) {
                    card.style.display = 'block';
                    card.style.animation = 'fadeInUp 0.4s ease forwards';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // Sorting buttons toggling
        function toggleSort(button) {
            const buttons = button.parentNode.querySelectorAll('.sort-pill');
            buttons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
        }

        // Interactive Rating Slider drag-n-click features
        const sliderTrack = document.getElementById('slider-track');
        const sliderFill = document.getElementById('slider-fill');
        const sliderHandle = document.getElementById('slider-handle');
        const ratingValText = document.getElementById('rating-value');
        let isDragging = false;

        function updateSliderValue(clientX) {
            const rect = sliderTrack.getBoundingClientRect();
            let position = (clientX - rect.left) / rect.width;
            position = Math.max(0, Math.min(1, position)); // Keep inside boundaries
            
            const ratingVal = (position * 10).toFixed(1);
            
            // Set visuals
            sliderFill.style.width = (position * 100) + '%';
            sliderHandle.style.left = (position * 100) + '%';
            ratingValText.textContent = ratingVal;
            
            // Highlight cards based on rating if desired
            filterMoviesByRating(parseFloat(ratingVal));
        }

        function adjustRatingSlider(event) {
            updateSliderValue(event.clientX);
        }

        function startDrag(event) {
            isDragging = true;
            event.preventDefault();
            document.addEventListener('mousemove', dragHandler);
            document.addEventListener('mouseup', stopDragHandler);
        }

        function dragHandler(event) {
            if (isDragging) {
                updateSliderValue(event.clientX);
            }
        }

        function stopDragHandler() {
            isDragging = false;
            document.removeEventListener('mousemove', dragHandler);
            document.removeEventListener('mouseup', stopDragHandler);
        }

        // Dynamic Filtering based on Slider Rating value
        function filterMoviesByRating(minRating) {
            const cards = document.querySelectorAll('#movies-cards-grid .movie-card');
            cards.forEach(card => {
                const ratingSpan = card.querySelector('.movie-card-rating-val');
                if (ratingSpan) {
                    const rating = parseFloat(ratingSpan.textContent);
                    if (!isNaN(rating) && rating >= minRating) {
                        card.style.opacity = '1';
                        card.style.pointerEvents = 'auto';
                        card.style.transform = 'none';
                    } else if (!isNaN(rating)) {
                        card.style.opacity = '0.35';
                        card.style.transform = 'scale(0.95)';
                    }
                }
            });
        }

        // Full Screen Video Streaming Simulation
        let streamModal = null;
        let bufferingTimeout = null;

        function playMovie(title, backdropUrl) {
            if (!streamModal) {
                streamModal = new bootstrap.Modal(document.getElementById('streamModal'));
            }
            
            // Populate Modal Content
            document.getElementById('modalMovieTitle').textContent = title.toUpperCase();
            document.getElementById('modalBackdropImg').style.backgroundImage = `url('${backdropUrl}')`;
            
            const spinner = document.querySelector('#streamPlayerContainer .spinner-border');
            const statusText = document.getElementById('streamStatusText');
            
            // Reset modal playing state visualizer
            spinner.style.display = 'inline-block';
            statusText.textContent = "BUFFERING CINEMATIC HIGH-SPEED STREAM...";
            statusText.classList.remove('text-success');
            statusText.classList.add('text-danger-emphasis');
            
            const playPauseIcon = document.querySelector('#streamPlayerContainer button i');
            playPauseIcon.className = 'bi bi-pause-fill fs-5';
            
            streamModal.show();

            // Simulate Buffering complete in 2 seconds
            if (bufferingTimeout) clearTimeout(bufferingTimeout);
            bufferingTimeout = setTimeout(() => {
                spinner.style.display = 'none';
                statusText.textContent = "NOW STREAMING IN ULTRA HD 4K (60 FPS)";
                statusText.classList.remove('text-danger-emphasis');
                statusText.classList.add('text-success');
            }, 2200);
        }

        function togglePlayState(btn) {
            const icon = btn.querySelector('i');
            const statusText = document.getElementById('streamStatusText');
            const spinner = document.querySelector('#streamPlayerContainer .spinner-border');
            
            if (icon.classList.contains('bi-pause-fill')) {
                icon.className = 'bi bi-play-fill fs-5';
                statusText.textContent = "PLAYBACK PAUSED";
                statusText.className = 'text-warning fs-5 mb-0';
                spinner.style.display = 'none';
                if (bufferingTimeout) clearTimeout(bufferingTimeout);
            } else {
                icon.className = 'bi bi-pause-fill fs-5';
                statusText.textContent = "NOW STREAMING IN ULTRA HD 4K (60 FPS)";
                statusText.className = 'text-success fs-5 mb-0';
            }
        }
    </script>
}
