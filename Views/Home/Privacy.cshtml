@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5" style="margin-top: 100px; min-height: 50vh;">
    <div class="p-5 rounded-4" style="background-color: #121212; border: 1px solid rgba(255, 255, 255, 0.05); box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <h1 class="text-danger fw-bold mb-4"><i class="bi bi-shield-lock me-2"></i> @ViewData["Title"]</h1>
        <p class="text-secondary" style="font-size: 1.1rem; line-height: 1.8;">
            Use this page to detail your site's privacy policy. In this Netflix-themed streaming site, your credentials, search history, and watch lists are kept secure. We value your privacy and aim to provide the most personalized, high-performance experience possible.
        </p>
        <hr class="bg-secondary my-4">
        <h3 class="text-light mb-3">Data Collection</h3>
        <p class="text-muted">
            We collect information about your interactions with our streaming services, including search queries, watch statistics, and preference filters to refine the smart ranking algorithms on your "Trends Now" feed.
        </p>
    </div>
</div>
