<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Netflix</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Premium site.css custom styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebMovie.styles.css" asp-append-version="true" />
    <style>
        .search-box-wrapper {
            border: 1px solid white;
            height: 34px;
            background-color: black;
            transition: all 0.3s ease;
        }
        .netflix-search-input {
            background: transparent;
            border: none;
            color: white;
            outline: none;
            width: 220px;
            padding: 0 10px;
            font-size: 0.9rem;
        }
        .netflix-search-input::placeholder {
            color: #aaa;
        }
    </style>
</head>
<body>
    <!-- Sticky Glassmorphic Header -->
    <header class="main-header py-3">
        <nav class="navbar navbar-expand-lg navbar-dark px-4">
            <div class="container-fluid">
                <!-- Red Netflix Logo -->
                <a class="navbar-brand brand-logo text-danger fw-black" asp-controller="Home" asp-action="Index">NETFLIX</a>
                
                <!-- Mobile Toggler -->
                <button class="navbar-toggler hamburger-menu-btn" type="button" data-bs-toggle="collapse" data-bs-target="#movieNavbar" aria-controls="movieNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list"></i>
                </button>
                
                <!-- Navbar Collapse Links -->
                <div class="collapse navbar-collapse" id="movieNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 navbar-menu-links ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Shows</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Movies</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Games</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Latest</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">My List</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Browse by Languages</a>
                        </li>
                    </ul>
                    
                    <!-- Search, Notification & Profile Actions -->
                    <div class="d-flex align-items-center header-actions ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <!-- Interactive Search -->
                            <div class="search-container me-4 d-flex align-items-center position-relative" id="searchContainer">
                                <a href="#" class="text-white fs-5 text-decoration-none" id="searchIconBtn" onclick="toggleSearch(event)"><i class="bi bi-search"></i></a>
                                <div class="search-box-wrapper d-none align-items-center" id="searchBoxWrapper">
                                    <i class="bi bi-search text-white ms-2" style="font-size: 1.1rem;"></i>
                                    <input type="text" class="netflix-search-input" placeholder="Titles, people, genres" id="netflixSearchInput">
                                </div>
                            </div>
                            <a href="#" class="text-white me-4 text-decoration-none" style="font-size: 0.95rem;">Kids</a>
                            <a href="#" class="text-white me-4 fs-5"><i class="bi bi-bell"></i></a>
                            
                            <!-- Profile Dropdown -->
                            <div class="profile-dropdown dropdown">
                                <a class="nav-link dropdown-toggle text-white d-flex align-items-center p-0" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="gap: 5px;">
                                    <img src="/images/admin_profile.jpg" alt="Profile" class="profile-avatar" style="width: 32px; height: 32px; border-radius: 4px !important; object-fit: cover;">
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark border-0 rounded-0 p-0 pb-2" style="background-color: rgba(0,0,0,0.9); margin-top: 15px !important; font-size: 0.85rem; width: 220px;">
                                    <!-- Top pointing arrow simulation -->
                                    <div style="position: absolute; top: -8px; right: 15px; width: 0; height: 0; border-left: 8px solid transparent; border-right: 8px solid transparent; border-bottom: 8px solid rgba(0,0,0,0.9);"></div>
                                    
                                    <div class="p-2">
                                        <li>
                                            <a class="dropdown-item py-2 d-flex align-items-center" href="#">
                                                <img src="/images/admin_profile.jpg" alt="Profile" style="width: 32px; height: 32px; border-radius: 4px; object-fit: cover; margin-right: 10px;">
                                                <span class="text-white text-truncate">@User.Identity.Name</span>
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2 d-flex align-items-center" href="#">
                                                <div style="width: 32px; height: 32px; border-radius: 4px; background: linear-gradient(135deg, #ff6b6b, #4ecdc4); margin-right: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: bold; color: white;">Kids</div>
                                                <span class="text-white">Kids</span>
                                            </a>
                                        </li>
                                    </div>
                                    
                                    <!-- App Actions -->
                                    <li><a class="dropdown-item py-2 text-white" asp-controller="Movie" asp-action="Create"><i class="bi bi-film me-3 fs-5 text-secondary"></i> Create Movie</a></li>
                                    <li><a class="dropdown-item py-2 text-white" asp-controller="Movie" asp-action="UploadEpisode"><i class="bi bi-cloud-arrow-up me-3 fs-5 text-secondary"></i> Upload Episode</a></li>
                                    
                                    <!-- Profile Actions -->
                                    <li><a class="dropdown-item py-2 text-white" href="#"><i class="bi bi-pencil me-3 fs-5 text-secondary"></i> Manage Profiles</a></li>
                                    <li><a class="dropdown-item py-2 text-white" href="#"><i class="bi bi-person-bounding-box me-3 fs-5 text-secondary"></i> Transfer Profile</a></li>
                                    <li><a class="dropdown-item py-2 text-white" href="#"><i class="bi bi-person me-3 fs-5 text-secondary"></i> Account</a></li>
                                    <li><a class="dropdown-item py-2 text-white" href="#"><i class="bi bi-question-circle me-3 fs-5 text-secondary"></i> Help Center</a></li>
                                    
                                    <li><hr class="dropdown-divider my-2" style="border-color: #333;"></li>
                                    
                                    <li>
                                        <a class="dropdown-item py-2 text-center text-white fw-bold" asp-controller="Account" asp-action="Logout" style="font-size: 0.85rem;">Sign out of Netflix</a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-premium btn-premium-red py-1.5 px-3 rounded text-white fw-bold" style="font-size: 0.85rem; border-radius: 4px !important;">Sign In</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Full-width Content Section -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- Sleek Cinematic Dark Footer -->
    <footer class="premium-footer">
        <div class="row gy-4">
            <!-- Resource Column -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <h5 class="footer-column-title">Resource</h5>
                <ul class="footer-links-list">
                    <li><a href="#">About</a></li>
                    <li><a href="#">Blockbuster</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Forums</a></li>
                    <li><a href="#">Gift Cards</a></li>
                    <li><a href="#">Help Center</a></li>
                </ul>
            </div>
            
            <!-- Legal Column -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <h5 class="footer-column-title">Legal</h5>
                <ul class="footer-links-list">
                    <li><a href="#">Terms Of Use</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                    <li><a href="#">Security</a></li>
                </ul>
            </div>
            
            <!-- Account Column -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <h5 class="footer-column-title">Account</h5>
                <ul class="footer-links-list">
                    <li><a href="#">My Account</a></li>
                    <li><a href="#">Watchlist</a></li>
                    <li><a href="#">Collections</a></li>
                    <li><a href="#">User Guide</a></li>
                </ul>
            </div>
            
            <!-- Newsletter Subscription Column -->
            <div class="col-lg-3 col-md-6 col-sm-12">
                <h5 class="footer-column-title">Newsletter</h5>
                <p class="newsletter-text">Subscribe to our newsletter system now to get latest news from us.</p>
                <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Subscribed successfully!');">
                    <input type="email" class="newsletter-input" placeholder="Your Email Address" required />
                    <button type="submit" class="newsletter-btn">Subscribe</button>
                </form>
            </div>
        </div>
        
        <div class="footer-bottom-divider"></div>
        
        <div class="footer-bottom-row">
            <div class="footer-bottom-left">
                <span><strong>IDN Netflix Cambodia</strong></span>
                <span>Call us (+855)096 66 17 223 </span>
            </div>
            <div class="footer-bottom-right">
                <span>&copy; @DateTime.Now.Year IDN Netflix Cambodia All Right Reserved.</span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Script to make header solid on scroll -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const header = document.querySelector('.main-header');
            window.addEventListener('scroll', function () {
                if (window.scrollY > 30) {
                    header.classList.add('scrolled');
                } else {
                    header.classList.remove('scrolled');
                }
            });
        });
    </script>
    
    <script>
        // Search bar expand logic
        function toggleSearch(e) {
            e.preventDefault();
            document.getElementById('searchIconBtn').classList.add('d-none');
            const wrapper = document.getElementById('searchBoxWrapper');
            wrapper.classList.remove('d-none');
            wrapper.classList.add('d-flex');
            document.getElementById('netflixSearchInput').focus();
        }
        
        document.addEventListener('click', function(e) {
            const container = document.getElementById('searchContainer');
            if (container && !container.contains(e.target)) {
                const input = document.getElementById('netflixSearchInput');
                if (input && input.value.trim() === '') {
                    document.getElementById('searchBoxWrapper').classList.add('d-none');
                    document.getElementById('searchBoxWrapper').classList.remove('d-flex');
                    document.getElementById('searchIconBtn').classList.remove('d-none');
                }
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
