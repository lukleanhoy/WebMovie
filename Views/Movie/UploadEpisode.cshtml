@model WebMovie.Models.EpisodeLink
@{
    ViewData["Title"] = "Upload Episode";
}

<div class="auth-page-container">
    <div class="auth-card" style="max-width: 600px;">
        <h2 class="auth-title">Upload Movie</h2>
        
        <!-- Optional Success Alert -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 bg-success bg-opacity-20 text-success mb-4 rounded-3">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            </div>
        }

        <form asp-controller="Movie" asp-action="UploadEpisode" method="post" autocomplete="off">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            }

            <!-- Select Movie -->
            <div class="auth-form-group">
                <label class="d-block mb-2 text-white-50 small fw-semibold">Select Movie</label>
                <select asp-for="MovieId" asp-items="ViewBag.Movies" class="auth-input" style="background-color: #333333; color: white;" required>
                    <option value="" disabled selected>-- Select Movie --</option>
                </select>
                <span asp-validation-for="MovieId" class="auth-input-error"></span>
            </div>

            <!-- Streaming Link -->
            <div class="auth-form-group">
                <input asp-for="Link" class="auth-input" placeholder=" " required />
                <label asp-for="Link" class="auth-input-label">Movie Streaming Link (URL)</label>
                <span asp-validation-for="Link" class="auth-input-error"></span>
            </div>

            <!-- Episode Number -->
            <div class="auth-form-group">
                <input asp-for="Episode" type="number" class="auth-input" placeholder=" " required min="1" />
                <label asp-for="Episode" class="auth-input-label">Episode Number</label>
                <span asp-validation-for="Episode" class="auth-input-error"></span>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-premium btn-premium-outline flex-grow-1 text-center justify-content-center">Cancel</a>
                <button type="submit" class="auth-btn flex-grow-1 mb-0">Add Movie</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
